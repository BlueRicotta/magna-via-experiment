{
  "expo": {
    "name": "Magna Via",
    "slug": "magna-via",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "magnavia",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "assets/images/**/*",
      "assets/fonts/**/*",
      "assets/icons/**/*"
    ],
    "icon": "./assets/icons/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bluericotta.magnavia",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bluericotta.magnavia",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#0a0a14"
      }
    },
    "web": {
      "bundler": "metro",
      "backgroundColor": "#050509",
      "favicon": "./assets/icons/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "fb9940c1-bfd9-43f6-a48e-90e666052062"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
